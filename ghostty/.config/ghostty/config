# Modern Ghostty Configuration - Graphite Theme

# Font settings
font-family = Hack Nerd Font
font-size = 16

# Window settings
window-padding-x = 20
window-padding-y = 20
window-height = 30
window-width = 120

# Theme colors - injected by scripts/switch-theme.sh
# THEME:START
background = #2f383e
foreground = #d3c6aa
# THEME:END
background-opacity = 0.85

# Terminal settings
term = xterm-ghostty
bold-is-bright = false

# GTK settings
gtk-single-instance = desktop
gtk-titlebar = true
gtk-tabs-location = top
gtk-wide-tabs = true

# Copy on select
copy-on-select = true

# Cursor customization
cursor-style = block
cursor-style-blink = true

# Shell integration
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# Scrollback
scrollback-limit = 10000

# Mouse support
mouse-hide-while-typing = true

# Clipboard improvements
clipboard-read = allow
clipboard-write = allow
clipboard-paste-protection = false

# -----------------------------------------------------------------------------
# Windows-style keybinds (Ctrl+C/V, Ctrl+T/W, etc.)
# -----------------------------------------------------------------------------
# Windows-style: Ctrl+C copies when text is selected, otherwise sends interrupt (SIGINT)
keybind = performable:ctrl+c=copy_to_clipboard
keybind = ctrl+v=paste_from_clipboard
keybind = ctrl+a=select_all

# Tabs
keybind = ctrl+t=new_tab
keybind = ctrl+w=close_tab
keybind = ctrl+tab=next_tab
keybind = ctrl+shift+tab=previous_tab
keybind = ctrl+shift+t=undo

# Splits
keybind = ctrl+shift+d=new_split:down
keybind = ctrl+shift+e=new_split:right
keybind = ctrl+alt+left=goto_split:left
keybind = ctrl+alt+right=goto_split:right
keybind = ctrl+alt+up=goto_split:up
keybind = ctrl+alt+down=goto_split:down

# Window
keybind = ctrl+n=new_window
keybind = ctrl+shift+w=close_window
keybind = ctrl+q=quit

# Font size
keybind = ctrl+plus=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+0=reset_font_size

# Scroll
keybind = shift+page_up=scroll_page_up
keybind = shift+page_down=scroll_page_down
keybind = ctrl+shift+home=scroll_to_top
keybind = ctrl+shift+end=scroll_to_bottom

# Misc
keybind = ctrl+l=clear_screen
keybind = ctrl+comma=open_config
keybind = ctrl+shift+r=reload_config
